<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
    <FileVersion major="1" minor="6" />
    <Project>
        <Option title="Paczkomat" />
        <Option pch_mode="2" />
        <Option compiler="gcc" />
        <Build>
            <!-- ── Release ──────────────────────────────────────────── -->
            <Target title="Release">
                <Option output="bin/Release/Paczkomat" prefix_auto="1" extension_auto="1" />
                <Option object_output="obj/Release/" />
                <Option type="0" />
                <Option compiler="gcc" />
                <Compiler>
                    <Add option="-std=c++17" />
                    <Add option="-O2" />
                    <Add option="-Wall" />
                    <Add option="-DUNICODE" />
                    <Add option="-D_UNICODE" />
                </Compiler>
                <Linker>
                    <Add option="-mwindows" />
                    <Add library="comctl32" />
                </Linker>
            </Target>
            <!-- ── Debug ────────────────────────────────────────────── -->
            <Target title="Debug">
                <Option output="bin/Debug/Paczkomat" prefix_auto="1" extension_auto="1" />
                <Option object_output="obj/Debug/" />
                <Option type="0" />
                <Option compiler="gcc" />
                <Compiler>
                    <Add option="-std=c++17" />
                    <Add option="-g" />
                    <Add option="-Wall" />
                    <Add option="-DUNICODE" />
                    <Add option="-D_UNICODE" />
                </Compiler>
                <Linker>
                    <!-- Keep -mwindows so no console pops up.          -->
                    <!-- Remove it temporarily if you need stdout debug.-->
                    <Add option="-mwindows" />
                    <Add library="comctl32" />
                </Linker>
            </Target>
        </Build>
        <Compiler>
            <Add option="-std=c++17" />
            <Add option="-Wall" />
            <Add option="-DUNICODE" />
            <Add option="-D_UNICODE" />
        </Compiler>
        <Linker>
            <Add option="-mwindows" />
            <Add library="comctl32" />
        </Linker>
        <!-- ── Source files ─────────────────────────────────────────── -->
        <Unit filename="main_gui.cpp">
            <Option compilerVar="CPP" />
        </Unit>
        <Unit filename="Paczka.cpp">
            <Option compilerVar="CPP" />
        </Unit>
        <Unit filename="Paczka.h">
            <Option compilerVar="CPP" />
        </Unit>
        <Unit filename="Skrytka.cpp">
            <Option compilerVar="CPP" />
        </Unit>
        <Unit filename="Skrytka.h">
            <Option compilerVar="CPP" />
        </Unit>
        <Unit filename="Paczkomat.cpp">
            <Option compilerVar="CPP" />
        </Unit>
        <Unit filename="Paczkomat.h">
            <Option compilerVar="CPP" />
        </Unit>
        <!-- Menu.cpp / Menu.h and the old main.cpp are NOT included:  -->
        <!-- the GUI replaces them entirely.                            -->
        <Extensions>
            <code_completion />
            <envvars />
            <debugger />
        </Extensions>
    </Project>
</CodeBlocks_project_file>
